# ============================================
# Humanity Protocol OAuth Configuration
# ============================================
# Get these from the Humanity Protocol Developer Dashboard
# https://developer.humanity.org

# Your application's OAuth client ID
HUMANITY_CLIENT_ID=your_client_id_here

# Your application's OAuth client secret (starts with sk_)
HUMANITY_CLIENT_SECRET=sk_your_client_secret_here

# The callback URL registered in your OAuth application
# Must match exactly what's configured in the Developer Dashboard
HUMANITY_REDIRECT_URI=http://localhost:3001/callback

# Environment: "sandbox" or "production"
HUMANITY_ENVIRONMENT=sandbox

# ============================================
# Your Application's JWT Configuration
# ============================================
# These are for YOUR app's authentication system, not Humanity Protocol

# Secret key for signing your application's JWTs
# IMPORTANT: Use a strong, random string of at least 32 characters
# Generate one with: openssl rand -base64 32
APP_JWT_SECRET=your_super_secret_jwt_key_change_me_in_production

# Issuer claim for your JWTs (identifies your application)
# Default: my-app
APP_JWT_ISSUER=my-awesome-app

# Token expiration time in seconds
# Default: 3600 (1 hour)
APP_JWT_EXPIRES_IN=3600
