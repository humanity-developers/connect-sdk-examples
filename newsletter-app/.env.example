# ===========================================
# Humanity Protocol OAuth Configuration
# ===========================================
HUMANITY_CLIENT_ID=your_client_id
HUMANITY_CLIENT_SECRET=your_client_secret
HUMANITY_REDIRECT_URI=http://localhost:3100/callback
HUMANITY_BASE_URL=https://api.humanity.org

# ===========================================
# MongoDB Configuration
# ===========================================
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=newsletter-app

# ===========================================
# News API (GNews.io)
# Get your free API key at: https://gnews.io/
# ===========================================
NEWS_API_KEY=your_gnews_api_key
NEWS_API_BASE_URL=https://gnews.io/api/v4

# ===========================================
# App JWT Configuration
# Generate secret with: openssl rand -base64 32
# ===========================================
APP_JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
APP_JWT_ISSUER=newsletter-app
APP_JWT_EXPIRES_IN=86400

# ===========================================
# Vercel Cron Job Secret (production only)
# ===========================================
CRON_SECRET=your_cron_secret


# ===========================================
# Humanity App URL (for social connections redirect)
# ===========================================
NEXT_PUBLIC_HUMANITY_APP_URL=https://app.humanity.org

# ===========================================
# Base Path Configuration (for proxy deployments)
# ===========================================
NEXT_PUBLIC_BASE_PATH=
