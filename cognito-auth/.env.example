# ============================================
# Humanity Protocol Configuration
# ============================================
# Get these from https://developer.humanity.org

# Your HP OAuth application client ID (starts with hp_)
HUMANITY_CLIENT_ID=your_client_id_here

# Your HP OAuth client secret (starts with sk_)
HUMANITY_CLIENT_SECRET=sk_your_client_secret_here

# Humanity API environment: "sandbox" or "production"
HUMANITY_ENVIRONMENT=sandbox

# ============================================
# AWS Cognito Configuration
# ============================================
# In a real deployment, your backend validates Cognito JWTs from your user pool.
# The HP API also needs access to verify them (configured via server env vars).

# Your Cognito User Pool ID (e.g. us-east-1_xxxxxxxx)
# Only needed if you verify Cognito tokens yourself in this app.
# The HP API reads COGNITO_USER_POOL_ID / COGNITO_REGION on its own.
COGNITO_USER_POOL_ID=us-east-1_yourPoolId
COGNITO_REGION=us-east-1
COGNITO_CLIENT_ID=your_cognito_app_client_id

# ============================================
# Session
# ============================================
# Secret for signing the example's cookie session
# Generate: openssl rand -base64 32
SESSION_SECRET=change_me_to_a_random_32_char_secret
