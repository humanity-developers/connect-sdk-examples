# ============================================================
# AWS Cognito — Your User Pool
# ============================================================

# AWS region of the User Pool
COGNITO_REGION=us-east-1

# User Pool ID from the Cognito console (e.g. us-east-1_AbCdEf123)
COGNITO_USER_POOL_ID=us-east-1_AbCdEf123

# App Client ID — used for audience validation and the Hosted UI login flow
COGNITO_CLIENT_ID=1a2b3c4d5e6f7g8h9i0j

# App Client Secret — required if your Cognito App Client has a secret
# Leave blank for public clients
COGNITO_CLIENT_SECRET=

# Cognito Hosted UI domain (without https://)
# e.g. myapp.auth.us-east-1.amazoncognito.com
COGNITO_DOMAIN=myapp.auth.us-east-1.amazoncognito.com

# Where Cognito redirects after login — must match your App Client settings
COGNITO_CALLBACK_URL=http://localhost:3000/auth/callback

# ============================================================
# Humanity Protocol — Your Application
# ============================================================
# Get these from https://developers.humanity.org
# After creating an app, configure Cognito via:
#   PUT https://api.humanity.org/v2/developer/applications/<clientId>
#   { cognitoRegion, cognitoUserPoolId, cognitoClientId }

HUMANITY_CLIENT_ID=app_9cdb0787fad6118dc18a49fc84389a46
HUMANITY_CLIENT_SECRET=sk_6497734a8d163bb750110473854f4b7b

# API base URL
HUMANITY_API_URL=https://api.humanity.org

# Frontend / consent UI base URL
HUMANITY_AUTH_URL=https://app.humanity.org

# Where HP redirects after the consent flow — must be registered on your HP app
HUMANITY_REDIRECT_URI=http://localhost:3000/consent/callback

# Space-separated scopes to request in the consent flow
HUMANITY_SCOPES=openid identity:read profile.full

# ============================================================
# Session
# ============================================================
# Secret for signing the session cookie — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_secret

PORT=3000
