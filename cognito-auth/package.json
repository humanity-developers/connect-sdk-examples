{
  "name": "hp-cognito-auth-example",
  "version": "0.1.0",
  "private": true,
  "description": "Example Express app: exchange an AWS Cognito JWT for a Humanity Protocol OAuth token (JWT Bearer Grant)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@humanity-org/connect-sdk": "^0.1.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.19.2",
    "express-session": "^1.18.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/node": "^20.16.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "packageManager": "bun@1.1.22"
}
